#===========================================
#NexusFlowBackendEnvironmentConfiguration
#===========================================

#Environment
NODE_ENV=development

#===========================================
#Database(PostgreSQL)
#===========================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=nexusflow
DB_PASSWORD=your_secure_password
DB_NAME=nexusflow
DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=public"

#===========================================
#Redis(optional-fallsbacktoin-memory)
#===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

#===========================================
#CacheConfiguration
#===========================================
CACHE_TTL_DEFAULT=300
CACHE_TTL_DASHBOARD=300

#===========================================
#JWTAuthentication
#===========================================
JWT_SECRET=your_jwt_secret_key_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

#===========================================
#Server
#===========================================
PORT=3000

#===========================================
#EmailConfiguration
#===========================================
#EmailProvider(sendgrid,nodemailer,console)
EMAIL_PROVIDER=console

#SMTPSettings(fornodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=rcyldeksvegyoyee

#SendGridSettings
SENDGRID_API_KEY=

#EmailSettings
EMAIL_FROM_NAME=NexusFlow
EMAIL_FROM_ADDRESS=noreply@nexusflow.com

#===========================================
#FrontendURL(foremaillinks)
#===========================================
FRONTEND_URL=http://localhost:3001

#===========================================
#QueueConfiguration(BullMQ)
#===========================================
#Settofalsetodisablebackgroundjobprocessing
QUEUE_ENABLED=true
#PrefixforallqueuenamesinRedis
QUEUE_PREFIX=nexusflow
#Defaultretryattemptsforfailedjobs
QUEUE_DEFAULT_ATTEMPTS=3
#Defaultbackoffdelayinmilliseconds
QUEUE_DEFAULT_BACKOFF_DELAY=1000

#Storagetype:'local'or's3'
STORAGE_TYPE=local

#Localstorage
UPLOAD_DIR=./uploads
UPLOAD_SECRET=your-secret-key

#S3(optional)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
S3_BUCKET=nexusflow-uploads
S3_ENDPOINT=...#ForMinIO
