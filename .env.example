# ===========================================
# NexusFlow Backend - Environment Configuration
# ===========================================
# Copy this file to create environment-specific configs:
#   - .env.local       → Local development
#   - .env.staging     → Staging environment
#   - .env.production  → Production environment
#
# Loading order (first found wins):
#   1. .env.{NODE_ENV}.local
#   2. .env.{NODE_ENV}
#   3. .env.local
#   4. .env

# ===========================================
# Environment
# ===========================================
# Options: development, staging, production
NODE_ENV=development

# ===========================================
# Database (PostgreSQL)
# ===========================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=nexusflow
DB_PASSWORD=your_secure_password
DB_NAME=nexusflow
DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=public"

# Connection pool settings (for production)
# Add to DATABASE_URL: &connection_limit=20&pool_timeout=30

# ===========================================
# Redis
# ===========================================
# Optional - falls back to in-memory cache if not configured
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}
# With password: redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}
# With TLS (production): rediss://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}

# ===========================================
# Cache Configuration
# ===========================================
# TTL in seconds
CACHE_TTL_DEFAULT=300
CACHE_TTL_DASHBOARD=300

# ===========================================
# JWT Authentication
# ===========================================
# IMPORTANT: Generate strong secrets for production
# Run: openssl rand -base64 64
JWT_SECRET=your_jwt_secret_key_min_32_characters_long
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ===========================================
# Server
# ===========================================
PORT=3000

# ===========================================
# Rate Limiting
# ===========================================
THROTTLE_TTL=60000      # Window in milliseconds (60 seconds)
THROTTLE_LIMIT=60       # Max requests per window

# ===========================================
# Email Configuration
# ===========================================
# Provider options: sendgrid, nodemailer, console
EMAIL_PROVIDER=console

# SMTP Settings (for nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

# SendGrid Settings
SENDGRID_API_KEY=

# Email Identity
EMAIL_FROM_NAME=NexusFlow
EMAIL_FROM_ADDRESS=noreply@nexusflow.com

# ===========================================
# Frontend URL
# ===========================================
# Used for email links and CORS
FRONTEND_URL=http://localhost:3001

# ===========================================
# Queue Configuration (BullMQ)
# ===========================================
QUEUE_ENABLED=true
QUEUE_PREFIX=nexusflow
QUEUE_DEFAULT_ATTEMPTS=3
QUEUE_DEFAULT_BACKOFF_DELAY=1000

# ===========================================
# Storage Configuration
# ===========================================
# Type options: local, s3
STORAGE_TYPE=local

# Local Storage
UPLOAD_DIR=./uploads
UPLOAD_SECRET=your_upload_secret_key

# S3 / MinIO Settings
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=nexusflow-uploads
S3_ENDPOINT=                    # Required for MinIO, optional for AWS S3

# MinIO (local development)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ===========================================
# Logging & Monitoring
# ===========================================
# Log level: error, warn, info, debug, verbose
LOG_LEVEL=debug

# Sentry Error Tracking
SENTRY_DSN=

# ===========================================
# CORS Configuration
# ===========================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3001

# ===========================================
# Security (Production)
# ===========================================
ENABLE_HELMET=false
ENABLE_COMPRESSION=false
