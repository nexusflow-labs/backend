# ===========================================
# NexusFlow Backend Environment Configuration
# ===========================================

# Environment
NODE_ENV=development

# ===========================================
# Database (PostgreSQL)
# ===========================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=nexusflow
DB_PASSWORD=your_secure_password
DB_NAME=nexusflow
DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=public"

# ===========================================
# Redis (optional - falls back to in-memory)
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

# ===========================================
# Cache Configuration
# ===========================================
CACHE_TTL_DEFAULT=300
CACHE_TTL_DASHBOARD=300

# ===========================================
# JWT Authentication
# ===========================================
JWT_SECRET=your_jwt_secret_key_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ===========================================
# Server
# ===========================================
PORT=3000

# ===========================================
# Email Configuration
# ===========================================
# Email Provider (sendgrid, nodemailer, console)
EMAIL_PROVIDER=console

# SMTP Settings (for nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=rcyl deks vegy oyee

# SendGrid Settings
SENDGRID_API_KEY=

# Email Settings
EMAIL_FROM_NAME=NexusFlow
EMAIL_FROM_ADDRESS=noreply@nexusflow.com

# ===========================================
# Frontend URL (for email links)
# ===========================================
FRONTEND_URL=http://localhost:3001

# ===========================================
# Queue Configuration (BullMQ)
# ===========================================
# Set to false to disable background job processing
QUEUE_ENABLED=true
# Prefix for all queue names in Redis
QUEUE_PREFIX=nexusflow
# Default retry attempts for failed jobs
QUEUE_DEFAULT_ATTEMPTS=3
# Default backoff delay in milliseconds
QUEUE_DEFAULT_BACKOFF_DELAY=1000
