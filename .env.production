# ===========================================
# Production Environment
# ===========================================
# IMPORTANT: This file is a TEMPLATE only.
# In production, inject secrets via:
# - Environment variables (Docker, K8s)
# - Secret managers (AWS Secrets Manager, Vault, etc.)
# - CI/CD pipeline secrets
#
# NEVER commit actual production secrets to git!

NODE_ENV=production

# ===========================================
# Database (PostgreSQL)
# ===========================================
# Use managed database with connection pooling
DB_HOST=${DB_HOST}
DB_PORT=${DB_PORT:-5432}
DB_USER=${DB_USER}
DB_PASSWORD=${DB_PASSWORD}
DB_NAME=${DB_NAME:-nexusflow}
DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=public&connection_limit=20&pool_timeout=30"

# ===========================================
# Redis
# ===========================================
# Use managed Redis with TLS in production
REDIS_HOST=${REDIS_HOST}
REDIS_PORT=${REDIS_PORT:-6379}
REDIS_PASSWORD=${REDIS_PASSWORD}
REDIS_TLS=${REDIS_TLS:-true}
REDIS_URL=${REDIS_URL}
# Format: rediss://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT} (rediss = TLS)

# ===========================================
# Cache Configuration
# ===========================================
# Longer TTL for production
CACHE_TTL_DEFAULT=600
CACHE_TTL_DASHBOARD=600

# ===========================================
# JWT Authentication
# ===========================================
# CRITICAL: Use cryptographically strong secrets (min 64 chars)
# Generate with: openssl rand -base64 64
JWT_SECRET=${JWT_SECRET}
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ===========================================
# Server
# ===========================================
PORT=3000

# ===========================================
# Rate Limiting (stricter for production)
# ===========================================
THROTTLE_TTL=60000
THROTTLE_LIMIT=60

# ===========================================
# Email Configuration
# ===========================================
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=${SENDGRID_API_KEY}

# SMTP Alternative
SMTP_HOST=${SMTP_HOST}
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=${SMTP_USER}
SMTP_PASSWORD=${SMTP_PASSWORD}

# Email Settings
EMAIL_FROM_NAME=NexusFlow
EMAIL_FROM_ADDRESS=noreply@nexusflow.com

# ===========================================
# Frontend URL
# ===========================================
FRONTEND_URL=${FRONTEND_URL:-https://app.nexusflow.com}

# ===========================================
# Queue Configuration (BullMQ)
# ===========================================
QUEUE_ENABLED=true
QUEUE_PREFIX=nexusflow-prod
QUEUE_DEFAULT_ATTEMPTS=5
QUEUE_DEFAULT_BACKOFF_DELAY=2000

# ===========================================
# Storage Configuration (S3)
# ===========================================
STORAGE_TYPE=s3

# AWS S3
AWS_REGION=${AWS_REGION:-us-east-1}
AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID}
AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY}
S3_BUCKET=${S3_BUCKET:-nexusflow-production-uploads}
# S3_ENDPOINT not needed for real AWS S3

# ===========================================
# Logging & Monitoring
# ===========================================
LOG_LEVEL=info

# Sentry Error Tracking
SENTRY_DSN=${SENTRY_DSN}

# ===========================================
# CORS
# ===========================================
CORS_ORIGINS=https://app.nexusflow.com

# ===========================================
# Security Headers
# ===========================================
ENABLE_HELMET=true
ENABLE_COMPRESSION=true
